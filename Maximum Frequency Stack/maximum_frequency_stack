from collections import deque

class Node:
    def __init__(self, val, next = None):
        self.val = val
        self.next = next

class Stack:
    def __init__(self):
        self.head = None
        self.size = 0

    def push(self, item):
        self.head = Node(item, self.head)
        self.size += 1

    def pop(self):
        val = self.head.val
        self.head = self.head.next
        self.size -= 1
        return val

    def peek(self):
        return self.head.val

    def is_empty(self):
        return self.head is None

    def __len__(self):
        return self.size

class FreqStack:

    def __init__(self):
        self.freq = {}
        self.group = defaultdict(deque)
        self.max_freq = 0

    def push(self, val: int) -> None:
        f = self.freq.get(val, 0) + 1
        self.freq[val] = f
        self.group[f].append(val)
        if f > self.max_freq:
            self.max_freq = f

    def pop(self) -> int:
        val = self.group[self.max_freq].pop()
        self.freq[val] -= 1
        if not self.group[self.max_freq]:
            self.max_freq -= 1
        return val
            
        


